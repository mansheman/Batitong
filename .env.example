# =============================================================================
# Batitong — environment configuration template
# =============================================================================
# Copy to .env and fill in values. NEVER commit .env to git.
#   cp .env.example .env
# -----------------------------------------------------------------------------

# --- Django ------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.dev
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-please-use-a-strong-random-value
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
TIME_ZONE=UTC

# Used to derive a Fernet key for encrypting per-workspace secrets stored in DB.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-with-a-real-fernet-key-44-bytes-long==

# --- Database ----------------------------------------------------------------
POSTGRES_DB=batitong
POSTGRES_USER=batitong
POSTGRES_PASSWORD=batitong
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis (Celery + Channels) -----------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- MCP Endpoints (internal docker network) --------------------------------
KALI_MCP_URL=http://kali-mcp:5000/mcp
HEXSTRIKE_API_URL=http://hexstrike-api:8888

# --- Ollama (local LLM, opsional di Phase 2) --------------------------------
OLLAMA_BASE_URL=http://ollama:11434
# Comma-separated list of models that the ollama-init service will pull.
# CPU-friendly:  qwen2.5-coder:7b, llama3.1:8b, phi3:mini
# GPU-preferred: qwen2.5:14b-instruct
OLLAMA_PULL_MODELS=qwen2.5-coder:7b,llama3.1:8b,phi3:mini

# --- GitHub Models (cloud LLM, opsional, Phase 2) ---------------------------
# Generate at https://github.com/settings/personal-access-tokens
# Required scope: models:read (fine-grained PAT)
# If unset, GitHub Models adapter is disabled.
# Prefer: store the PAT as a per-workspace credential (Settings → Credentials)
# instead of putting it in .env — credentials are Fernet-encrypted at rest.
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_BASE_URL=https://models.inference.ai.azure.com
# One of: gpt-4o-mini | Phi-3.5-MoE-instruct | Llama-3.3-70B-Instruct
GITHUB_MODELS_DEFAULT_MODEL=gpt-4o-mini

# --- LLM router (Phase 2A) --------------------------------------------------
# Default provider when a workspace has no explicit setting.
# One of: ollama | github_models
LLM_DEFAULT_PROVIDER=ollama
# Prompt-logging mode for LLMTrace rows. Per-workspace privacy_mode toggle in
# Settings can also force hashing on top of this baseline.
# One of: full | hash | off
LLM_PROMPT_LOGGING=full
# How many tool-call iterations a single chat turn may take before giving up.
LLM_MAX_TOOL_ITERATIONS=4
# Max characters of tool output fed back into the LLM context per turn.
LLM_TOOL_OUTPUT_CHAR_LIMIT=4000

# --- Approval gate (Phase 2A) ----------------------------------------------
APPROVAL_GATE_ENABLED=1
# Pending approvals expire after this many minutes (sweep task).
APPROVAL_TIMEOUT_MINUTES=60

# --- Initial superuser (created on first migrate via entrypoint) ------------
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@batitong.local
DJANGO_SUPERUSER_PASSWORD=batitong-admin
